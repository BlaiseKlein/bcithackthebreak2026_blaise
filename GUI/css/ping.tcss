
#mainContainer {
    margin: 0;
    padding: 0;
}

#searchBar {
    margin: 0;
    padding: 0;
    height: 3;
}

#content {
    margin: 0;
    padding: 0;
    height: 1fr;
}

/* Make the two VerticalScrolls side by side */
#content {
    layout: horizontal;
}


/* Style individual elements */
#aiSearch {
    margin: 0;
    width: 100%;
}

SelectionList {
    margin: 0 0 1 0;
}

Input {
    margin: 0 0 0 0;
}

Button {
    margin: 1 2;
}


